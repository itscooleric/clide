# Docker Compose override — Caddy reverse proxy with basic auth
#
# Why: ttyd's built-in basic auth (--credential) is broken on iOS/Safari
# due to Apple's WebSocket implementation. Caddy handles auth instead.
#
# Setup:
#   1. Copy to docker-compose.override.yml
#   2. Generate password hash:
#        docker exec caddy caddy hash-password --plaintext 'yourpassword'
#   3. Replace the hash below (double $$ for compose escaping)
#   4. Set TTYD_AUTH_PROXY=true in .env
#   5. docker compose up -d web
#
# Requires: caddy-docker-proxy running on a 'caddy' Docker network
#   See: https://github.com/lucaslorentz/caddy-docker-proxy

services:
  web:
    networks:
      - default
      - caddy
    labels: !override
      caddy: "http://your-hostname:80"
      caddy.basic_auth: "*"
      caddy.basic_auth.admin: "$$2a$$14$$YOUR_HASH_HERE"
      caddy.reverse_proxy: "{{upstreams 7681}}"
      caddy.reverse_proxy.header_up: "X-Auth-User {http.auth.user.id}"

networks:
  caddy:
    external: true
