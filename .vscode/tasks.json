{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build clide image",
      "type": "shell",
      "command": "docker compose build",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Start web terminal (ttyd)",
      "type": "shell",
      "command": "docker compose up -d web && echo 'Web terminal at http://localhost:7681'",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Stop web terminal",
      "type": "shell",
      "command": "docker compose down",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Open CLI shell",
      "type": "shell",
      "command": "docker compose run --rm cli",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true },
      "problemMatcher": []
    }
  ]
}
