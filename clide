#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

usage() {
  cat <<EOF
clide вҖ” CLI Development Environment

Usage: ./clide <command> [args]

Commands:
  web         Start web terminal at http://localhost:7681
  web-stop    Stop the web terminal
  shell       Open interactive shell (all CLIs available)
  copilot     Run GitHub Copilot CLI
  gh [args]   Run GitHub CLI (pass args after)
  claude      Run Claude Code CLI
  codex       Run Codex CLI (OpenAI)
  build       Build the Docker image
  rebuild     Rebuild the Docker image (no cache)
  logs        Follow web terminal logs
  status      Show running containers
  help        Show this help

Examples:
  ./clide web                    # start web terminal
  ./clide shell                  # interactive shell
  ./clide copilot                # run copilot
  ./clide gh repo view           # run gh with args
  PROJECT_DIR=~/myrepo ./clide shell  # mount a specific project
  ./clide codex                  # run Codex CLI (OpenAI)
EOF
}

splash() {
  echo ""
  echo "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—     в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
  echo " в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ"
  echo " в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  "
  echo " в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  "
  echo " в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
  echo "  в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қ"
  echo ""
  echo "  CLI Development Environment"
  echo "  Copilot В· GitHub CLI В· Claude Code В· Codex CLI"
  echo ""
}

case "${1:-help}" in
  web)
    splash
    docker compose up -d web
    echo ""
    echo "  Web terminal running at http://localhost:7681"
    echo "  Stop with: ./clide web-stop"
    echo ""
    ;;
  web-stop)
    docker compose down
    ;;
  shell)
    splash
    docker compose run --rm shell
    ;;
  copilot)
    splash
    docker compose run --rm copilot
    ;;
  gh)
    shift
    docker compose run --rm gh "$@"
    ;;
  claude)
    splash
    CLAUDE_CODE_SIMPLE=1 docker compose run --rm claude
    ;;
  codex)
    splash
    docker compose run --rm codex
    ;;
  build)
    docker compose build
    ;;
  rebuild)
    docker compose build --no-cache
    ;;
  logs)
    docker compose logs -f web
    ;;
  status)
    docker compose ps
    ;;
  help|--help|-h|*)
    usage
    ;;
esac
