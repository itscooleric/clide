#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

usage() {
  cat <<EOF
clide ‚ÄĒ CLI Development Environment

Usage: ./clide <command> [args]

Commands:
  web         Start web terminal at http://localhost:7681
  web-stop    Stop the web terminal
  cli         Open interactive shell (all CLIs available)
  build       Build the Docker image
  rebuild     Rebuild the Docker image (no cache)
  logs        Follow web terminal logs
  status      Show running containers
  help        Show this help

Examples:
  ./clide web                    # start web terminal
  ./clide cli                    # interactive shell ‚ÄĒ run claude, copilot, codex, gh from here
  PROJECT_DIR=~/myrepo ./clide shell  # mount a specific project
  ./clide codex                  # run Codex CLI (OpenAI)
  ./clide codex auth login --auth device
EOF
}

clide_version() {
  # Inside container: read baked-in version; outside: derive from git
  if [[ -f /etc/clide-version ]]; then
    cat /etc/clide-version
  elif command -v git &>/dev/null && git rev-parse --git-dir &>/dev/null 2>&1; then
    local sha branch
    sha=$(git rev-parse --short HEAD 2>/dev/null)
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    echo "${branch}@${sha}"
  else
    echo "dev"
  fi
}

splash() {
  local ver
  ver=$(clide_version)
  echo ""
  echo "  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó     ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó"
  echo " ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ"
  echo " ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  "
  echo " ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  "
  echo " ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó"
  echo "  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ"
  echo ""
  echo "  CLI Development Environment  (${ver})"
  echo "  Copilot ¬∑ GitHub CLI ¬∑ Claude Code ¬∑ Codex CLI"
  echo ""
}

case "${1:-help}" in
  web)
    splash
    docker compose up -d web
    echo ""
    echo "  Web terminal running at http://localhost:7681"
    echo "  Stop with: ./clide web-stop"
    echo ""
    ;;
  web-stop)
    docker compose down
    ;;
  cli|shell)
    splash
    docker compose run --rm cli
    ;;
  build)
    docker compose build
    ;;
  rebuild)
    docker compose build --no-cache
    ;;
  logs)
    docker compose logs -f web
    ;;
  status)
    docker compose ps
    ;;
  help|--help|-h|*)
    usage
    ;;
esac
